# =============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# =============================================================================

# Modo de operação: once (única execução), loop (contínuo), scheduled (agendado)
OPERATION_MODE=once

# Intervalo entre execuções em modo loop (segundos)
LOOP_INTERVAL_SECONDS=3600

# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# SHOPEE AFFILIATE API (GraphQL)
# =============================================================================

# App ID da Shopee Affiliate (solicitar no painel de afiliados)
SHOPEE_APP_ID=your_shopee_app_id_here

# Secret da Shopee Affiliate
SHOPEE_SECRET=your_shopee_secret_here

# URL da API GraphQL (default: https://open-api.affiliate.shopee.com.br/graphql)
SHOPEE_API_URL=https://open-api.affiliate.shopee.com.br/graphql

# Palavra-chave de busca (vazio = todas as ofertas recomendadas)
SHOPEE_SEARCH_KEYWORD=

# =============================================================================
# INSTAGRAM / META GRAPH API
# =============================================================================

# Access Token do Instagram (obter em developers.facebook.com)
# IMPORTANTE: Use um token de longa duração (60 dias) ou implemente refresh automático
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# ID da conta Instagram Business/Creator
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here

# Versão da API do Instagram
INSTAGRAM_API_VERSION=v18.0

# =============================================================================
# CONFIGURAÇÕES DE SELEÇÃO DE OFERTAS
# =============================================================================

# Rating mínimo do produto (0.0 - 5.0)
MIN_RATING=4.0

# Desconto mínimo em porcentagem
MIN_DISCOUNT=30.0

# Comissão mínima em porcentagem
MIN_COMMISSION=5.0

# Categorias permitidas (separadas por vírgula, vazio = todas)
# Exemplo: 100644,100372,100011
ALLOWED_CATEGORIES=

# =============================================================================
# CONFIGURAÇÕES DE COMENTÁRIOS
# =============================================================================

# Tempo de cooldown entre mensagens para o mesmo usuário (minutos)
COMMENT_COOLDOWN_MINUTES=60

# =============================================================================
# BANCO DE DADOS (OPCIONAL)
# =============================================================================

# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=achadinhos
# DB_USER=achadinhos
# DB_PASSWORD=changeme

# =============================================================================
# REDIS / CACHE (OPCIONAL)
# =============================================================================

# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
